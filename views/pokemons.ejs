<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Liste des Pokémons</title>
  </head>

  <body>
    <table border="1">
      <thead>
        <tr>
          <th>Nom</th>
          <th>Type</th>
        </tr>
      </thead>
      <tbody>
        <% pokemons.forEach(pokemon=> { %>
        <tr>
          <td><%= pokemon.name %></td>
          <td><%= pokemon.type %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>
